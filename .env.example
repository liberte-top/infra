# Copy to `.env` before running helper scripts.
# `INFRA_SSH_PRIVATE_KEY_B64` must be a single-line base64-encoded private key.
ANSIBLE_IMAGE=quay.io/ansible/creator-ee:v24.2.0
INFRA_SSH_HOST=
INFRA_SSH_USER=root
INFRA_SSH_PRIVATE_KEY_B64=
INFRA_KUBECONFIG_PATH=/etc/rancher/k3s/k3s.yaml
INFRA_KUBECTL_TUNNEL_LOCAL_PORT=56443
